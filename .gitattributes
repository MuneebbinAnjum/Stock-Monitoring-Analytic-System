# Normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto eol=lf

# Force LF for source code
*.cs text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.txt text eol=lf

# Binary files — do not touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.docx binary
*.pdf binary
*.zip binary
